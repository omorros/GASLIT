# GASLIT — environment template. Copy to .env and fill in.
# .env is gitignored. Never commit real keys.

# ─── MongoDB Atlas (Oriol) ─────────────────────────────────────────────
# From Atlas → Cluster0 → Connect → Drivers → Python 3.12+
# Replace <db_password> with the gaslit-app password.
MONGODB_URI=mongodb+srv://gaslit-app:<db_password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
MONGODB_DB=gaslit

# ─── Anthropic — Scribe / Librarian / Forensic Auditor ────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_FALLBACK_MODEL=claude-haiku-4-5-20251001

# ─── Voyage AI — embeddings ───────────────────────────────────────────
# https://dash.voyageai.com → API Keys
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3-large
VOYAGE_DIM=1024

# ─── Fireworks AI — adversary stream (Llama 3.3 70B) ──────────────────
# https://app.fireworks.ai → API Keys
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p3-70b-instruct
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# ─── LangSmith — tracing ──────────────────────────────────────────────
# https://smith.langchain.com → Settings → API Keys
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=gaslit-hackathon
LANGSMITH_TRACING=true
LANGSMITH_PROJECT_URL=https://smith.langchain.com/o/.../projects/p/gaslit-hackathon

# ─── HMAC provenance secret (Oriol generates) ─────────────────────────
# Production: MongoDB Queryable Encryption. Demo: env var.
HMAC_SECRET=<generate-locally:python -c "import secrets;print(secrets.token_hex(32))">

# ─── NVIDIA — Sentinel + Nemotron-backed Guardrails (Teammate 1) ─────
# https://build.nvidia.com → sign up → API key
NVIDIA_API_KEY=nvapi-...
NEMOTRON_MODEL=nvidia/nemotron-3-super-120b-a12b
NEMOTRON_BASE_URL=https://integrate.api.nvidia.com/v1

# NeMo Guardrails main LLM: anthropic (Haiku, default) or nvidia (Nemotron; requires langchain-openai).
# GUARDRAILS_MAIN_ENGINE=nvidia

# Sentinel dossier text: Nemotron retries once with larger max_tokens; Haiku fallback unless disabled.
# SENTINEL_ANTHROPIC_FALLBACK=0

# ─── AWS — Sentinel hosting (Teammate 1) ──────────────────────────────
AWS_REGION=eu-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── LiveKit — voice input (Teammate 2) ───────────────────────────────
# Dashboard: https://cloud.livekit.io → your project → Settings
#
# LIVEKIT_URL     = "WebSocket URL" / server URL (starts with wss://…livekit.cloud)
# LIVEKIT_API_KEY = "API key" (public identifier, not the JWT)
# LIVEKIT_API_SECRET = "API secret" (private — only on server / in .env, never in frontend code)
LIVEKIT_URL=wss://YOUR-PROJECT.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Same WebSocket URL as LIVEKIT_URL — used when syncing to frontend/.env.local (scripts/sync_frontend_env.py)
# and in Next’s env. Room URL for the client still comes from POST /api/livekit/token.
NEXT_PUBLIC_LIVEKIT_URL=wss://YOUR-PROJECT.livekit.cloud

# ─── ElevenLabs — voice output (Teammate 2) ───────────────────────────
# Dashboard: https://elevenlabs.io → profile / API keys; Conv AI → Agents for agent id
#
# ELEVENLABS_API_KEY = your API key (secret — keep in .env only)
# ELEVENLABS_AGENT_ID = Conversational AI agent id (public; same value can go in NEXT_PUBLIC_* below)
# Redeem the hackathon coupon emailed to you on event day.
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=
# Used when creating the Conv AI agent via API (English agents: flash v2 or turbo, not v2.5)
ELEVENLABS_CONVAI_TTS_MODEL=eleven_flash_v2
# TTS dossier readout (Flash v2.5) — defaults are fine unless you pick another voice/model
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
# Dossier TTS model (Flash v2.5). Same as ELEVENLABS_TTS_MODEL if you prefer that name.
ELEVENLABS_MODEL_ID=eleven_flash_v2_5

# ─── Operator Console personas (POST /api/voice/tts → persona param) ─
# Three voices the Operator Console scenario-director can call into:
#   adversary: speaks the MINJA implant in the cold open (sinister/low)
#   narrator:  calm AI announcer for live event narration
#   forensic:  PRD-locked dossier reader (defaults to ELEVENLABS_VOICE_ID above)
# Pick voice ids from https://elevenlabs.io/app/voice-library — leave empty to use sensible
# public-preset fallbacks (Antoni / Rachel / Adam).
ELEVENLABS_VOICE_ADVERSARY=
ELEVENLABS_VOICE_NARRATOR=
ELEVENLABS_VOICE_FORENSIC=
# Optional: same as ELEVENLABS_AGENT_ID — only if the Next bundle needs it without calling the API
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=
# Optional smoke test: real quarantine_id from MongoDB for /api/forensic-qa
NEXT_PUBLIC_DEMO_QUARANTINE_ID=
# GASLIT bridge WebSocket (quarantine → dossier TTS on the frontend). Default matches WS_PORT.
NEXT_PUBLIC_WS_URL=ws://127.0.0.1:8003

# ─── Service ports ────────────────────────────────────────────────────
API_PORT=8002
WS_PORT=8003

# ─── Demo dashboard / NemoClaw bridge (Teammate 1) ─────────────────────
# If you serve /demo from a different host than FastAPI (rare), set the API origin:
# DEMO_API_PUBLIC_URL=http://127.0.0.1:8002
#
# Full NVIDIA NemoClaw OpenShell is out-of-repo; this API mirrors its HTTP MINJA sequence:
#   python scripts/nemoclaw_minja_driver.py --api http://127.0.0.1:8002
# Persistent adversary (live red-team posture — what NemoClaw hosts):
#   python scripts/nemoclaw_minja_driver.py --api http://127.0.0.1:8002 --loop --forever --pause-between-cycles 45

# ─── Next.js frontend (optional; copy into frontend/.env.local) ───────
# NEXT_PUBLIC_LIVEKIT_URL is defined next to LiveKit above (same wss:// URL).
# Leave empty for local dev: Next.js proxies /backend → FastAPI (see frontend/next.config.ts).
# Set only if the browser must call the API directly (e.g. remote API).
NEXT_PUBLIC_API_BASE=
NEXT_PUBLIC_VOICE_TRANSCRIPTION_MODE=livekit
# Optional: override proxy target (default http://127.0.0.1:8002)
# BACKEND_PROXY_TARGET=http://127.0.0.1:8002
